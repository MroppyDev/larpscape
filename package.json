{
  "name": "larpscape",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run validate && tsc && vite build",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "start": "NODE_ENV=production tsx server/index.ts",
    "validate": "tsx scripts/validate-content.ts",
    "admin:dev": "vite --config admin/vite.config.ts",
    "admin:build": "vite build --config admin/vite.config.ts",
    "admin:server": "tsx admin/server/index.ts",
    "wiki:build-data": "tsx scripts/build-wiki.ts",
    "wiki:dev": "npm run wiki:build-data && vite --config wiki/vite.config.ts",
    "wiki:build": "npm run wiki:build-data && vite build --config wiki/vite.config.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "express": "^5.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "spessasynth_lib": "^4.3.7",
    "three": "^0.184.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  }
}
